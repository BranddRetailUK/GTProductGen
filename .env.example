# Product Gen local environment template.
# Copy to .env locally and mirror production values into Railway Variables.

# Core runtime
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URL=
DATABASE_SSL=
PG_BOSS_ENABLED=true
PRODUCT_GEN_SCAN_INTERVAL_MS=900000
PRODUCT_GEN_QUEUE_GENERATION=product-gen:generation-run
PRODUCT_GEN_QUEUE_DROPBOX_SCAN=product-gen:dropbox-scan

# Admin access
PRODUCT_GEN_ADMIN_EMAIL=
PRODUCT_GEN_ADMIN_PASSWORD=
PRODUCT_GEN_SESSION_SECRET=

# Dropbox artwork ingest
DROPBOX_ROOT_PATH=/
DROPBOX_ACCESS_TOKEN=
DROPBOX_REFRESH_TOKEN=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# Cloudinary rendered image output
CLOUDINARY_URL=
CLOUDINARY_UPLOAD_FOLDER=ImageGen

# Cloudinary base product image source
CLOUDINARY_BASE_CLOUD_NAME=
CLOUDINARY_BASE_API_KEY=
CLOUDINARY_BASE_API_SECRET=
CLOUDINARY_BASE_FOLDER=template_product_images

# Shopify Admin API publishing
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-04
SHOPIFY_PRODUCT_STATUS=draft
SHOPIFY_DEFAULT_VENDOR=Good Game Apparel
SHOPIFY_DEFAULT_PRODUCT_TYPE=
SHOPIFY_LOCATION_ID=
SHOPIFY_LOCATION_NAME=GG Apparel
SHOPIFY_DEFAULT_INVENTORY_QUANTITY=99

# Optional read-only source for syncing template product data from the main Good Game service.
GOOD_GAME_DATABASE_URL=
GOOD_GAME_DATABASE_SSL=true
